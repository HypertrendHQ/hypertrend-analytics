{
  "name": "hypertrend-analytics",
  "version": "2.6.0",
  "description": "HyperTrend 链上信用分析、排行榜数据访问、交易者风险匹配与 Hyperliquid 地址分析 Skill",
  "author": "HyperTrend Team",
