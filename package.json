  "keywords": [
    "hypertrend",
    "hyperliquid",
    "on-chain",
    "credit",
    "trading",
    "analytics",
    "copytrading",
    "leaderboard",
    "defi",
    "api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/GuiPulp/hypertrend-analytics"
  },
  "bugs": {
    "url": "https://github.com/GuiPulp/hypertrend-analytics/issues"
  },
  "homepage": "https://www.hypertrend.top/",
  "bin": {
    "hypertrend-cli": "scripts/hypertrend_cli.py"
  },
  "api": {
    "base_url": "https://app.hypertrend.top/api",
    "legacy_base_url": "http://192.144.239.66/api",
    "version": "v1"
  },
  "openclaw": {
    "minVersion": "1.0.0",
    "skillsPath": "~/.openclaw/skills/",
    "category": "finance",
    "tags": ["crypto", "trading", "analytics", "copytrading", "leaderboard", "api"]
  },
  "dependencies": {
    "apis": [
      {
        "name": "HyperTrend API",
        "url": "https://app.hypertrend.top/api",
        "auth": "optional_jwt",
        "docs": "https://github.com/GuiPulp/hypertrend-analytics/blob/main/API_CLIENT.md"
      },
      {
        "name": "Hyperliquid API",
        "url": "https://api.hyperliquid.xyz/info",
        "auth": "none",
        "docs": "https://hyperliquid.gitbook.io/hyperliquid-docs/"
      }
    ]
  },
  "features": {
    "analytics": true,
    "copytrading": true,
    "leaderboard": true,
    "platform_copytrading": true,
    "address_monitoring": true,
    "api_integration": true,
    "whale_monitoring": true,
    "tweet_generation": true
  },
  "config": {
    "env": [
      "HYPERTREND_API_URL",
      "HYPERTREND_API_TOKEN",
      "HYPERTREND_WALLET_ADDRESS",
      "HYPERTREND_API_SIGNATURE",
      "HYPERTREND_TRADING_ENABLED",
      "HYPERTREND_ALERT_TELEGRAM",
      "HYPERTREND_ALERT_DISCORD",
      "HYPERTREND_WHALE_THRESHOLD",
      "HYPERTREND_LIQUIDATION_ALERT"
    ]
  }
}
